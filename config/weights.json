{
  "score_bands": {
    "red": [0, 40],
    "yellow": [41, 70],
    "green": [71, 100]
  },
  "normalization": {
    "login_freq_per_wk": {"type": "linear", "min": 0, "max": 3},
    "feature_adoption_pct": {"type": "percent"},
    "support_tickets_per_mo": {"type": "inverted_linear", "min": 0, "max": 5},
    "days_since_engagement": {"type": "inverted_linear", "min": 0, "max": 30},
    "onboarding_completion_pct": {"type": "percent"},
    "nps_raw": {"type": "linear", "min": 0, "max": 10},
    "csm_pulse": {"type": "linear", "min": 1, "max": 5}
  },
  "segments": {
    "enterprise": {
      "login_freq_per_wk": {"weight": 15, "available": true},
